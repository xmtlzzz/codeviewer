{
  "productName": "CodeViewer",
  "version": "0.1.0",
  "identifier": "com.codeviewer.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd --prefix D:\\Desktop\\code\\Rust\\codeviewer\\frontend run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm.cmd --prefix D:\\Desktop\\code\\Rust\\codeviewer\\frontend run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CodeViewer",
        "width": 800,
        "height": 600,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"]
  }
}
