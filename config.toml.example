# CodeViewer 配置

author_email = "your-email@example.com"  # 只统计此作者的提交，留空则统计所有人
close_behavior = "minimize" # minimize hides to tray on close, exit quits the app

[[repos]]
# Windows 路径用单引号（literal string）避免反斜杠转义问题：
#   path = 'D:\code\my-project'
# 或使用正斜杠：
#   path = "D:/code/my-project"
# macOS/Linux 路径直接用双引号即可：
#   path = "/home/user/my-project"
path = "/path/to/your/project"

[scan]
interval_secs = 30   # 后台扫描间隔（秒），最低 5
since_days = 30      # 统计最近多少天的提交
